NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info

CORS_ORIGIN=*
BODY_LIMIT_BYTES=2097152
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Local dev (PostgreSQL rodando no host)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cpj_cobranca?schema=public

# Docker Compose (substitui localhost pelo nome do serviço)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cpj_cobranca?schema=public

OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_TITLE=CPJ Cobranca API AI
OPENROUTER_FETCH_GENERATION_STATS=true

GITHUB_TOKEN=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cpj-cobranca-api-ai

# WEBHOOK_CALLBACK_URL=https://example.com/webhook/cpj-cobranca
