### ========================================
### CPJ-Cobranca API - Manual Test Requests
### ========================================
### Base URL (local dev ou Docker)
@baseUrl = http://localhost:3000

### -----------------------
### Health Check
### -----------------------
GET {{baseUrl}}/health

### -----------------------
### POST Review - TypeScript
### -----------------------
POST {{baseUrl}}/api/v1/review
Content-Type: application/json

{
  "code": "function calculateTotal(items: { price: number; quantity: number }[]): number {\n  return items.reduce((sum, item) => {\n    return sum + item.price * item.quantity;\n  }, 0);\n}",
  "language": "typescript",
  "context": "Funcao de calculo de total em carrinho de compras",
  "model": "openai/gpt-4o-mini"
}

### -----------------------
### POST Review Stream - SSE
### -----------------------
POST {{baseUrl}}/api/v1/review/stream
Content-Type: application/json

{
  "code": "const data = await fetch('https://api.example.com/users');\nconst users = await data.json();\nconsole.log(users);",
  "language": "javascript",
  "context": "Busca de usuarios em API externa"
}

### -----------------------
### POST Review - Python
### -----------------------
POST {{baseUrl}}/api/v1/review
Content-Type: application/json

{
  "code": "def get_user(user_id):\n    conn = sqlite3.connect('database.db')\n    cursor = conn.cursor()\n    cursor.execute(f\"SELECT * FROM users WHERE id = {user_id}\")\n    return cursor.fetchone()",
  "language": "python",
  "context": "Funcao de consulta a banco SQLite"
}

### -----------------------
### POST Review - PHP
### -----------------------
POST {{baseUrl}}/api/v1/review
Content-Type: application/json

{
  "code": "<?php\nclass UserController {\n    public function getUser($id) {\n        global $db;\n        $result = mysqli_query($db, \"SELECT * FROM users WHERE id = $id\");\n        return mysqli_fetch_assoc($result);\n    }\n}",
  "language": "php",
  "context": "Controller PHP com SQL embutido"
}

### -----------------------
### POST Pull Request Review - sem Jira
### -----------------------
POST {{baseUrl}}/api/v1/review/pull-request
Content-Type: application/json

{
  "github_pull_request_url": "https://github.com/org/repo/pull/123",
  "base_branch": "main",
  "model": "openai/gpt-4o-mini"
}

### -----------------------
### POST Pull Request Review - com Jira
### -----------------------
POST {{baseUrl}}/api/v1/review/pull-request
Content-Type: application/json

{
  "github_pull_request_url": "https://github.com/org/repo/pull/123",
  "jira_issue_key": "CPJ-123",
  "base_branch": "main",
  "prompt_version": 1,
  "model": "openai/gpt-4o-mini"
}

### -----------------------
### POST Compliance
### -----------------------
POST {{baseUrl}}/api/v1/compliance
Content-Type: application/json

{
  "task_description": "Permitir renegociacao apenas para contratos ativos e registrar auditoria.",
  "code": "if (contract.active) { renegotiate(contract); audit(contract.id); }",
  "language": "typescript",
  "model": "deepseek/deepseek-v4-flash"
}

### -----------------------
### POST Document
### -----------------------
POST {{baseUrl}}/api/v1/document
Content-Type: application/json

{
  "code": "export async function chargeCustomer(customerId: string, amount: number) { if (amount <= 0) throw new Error('invalid amount'); await repository.save({ customerId, amount }); return { approved: true }; }",
  "language": "typescript",
  "doc_type": "technical",
  "model": "openai/gpt-4o-mini"
}

### -----------------------
### POST Tests
### -----------------------
POST {{baseUrl}}/api/v1/tests
Content-Type: application/json

{
  "code": "export function charge(amount: number) { if (amount <= 0) throw new Error('invalid amount'); return amount > 0; }",
  "language": "typescript",
  "test_framework": "vitest",
  "model": "deepseek/deepseek-v4-flash"
}

### -----------------------
### POST Tests from Pull Request
### -----------------------
POST {{baseUrl}}/api/v1/tests/pull-request
Content-Type: application/json

{
  "github_pull_request_url": "https://github.com/org/repo/pull/123",
  "base_branch": "main",
  "test_framework": "vitest",
  "model": "openai/gpt-4o-mini"
}

### -----------------------
### GET Prompt Versions
### -----------------------
GET {{baseUrl}}/api/v1/prompts?flow_type=review

### -----------------------
### GET Active Prompt Version
### -----------------------
GET {{baseUrl}}/api/v1/prompts/review/active

### -----------------------
### POST Create Prompt Version
### -----------------------
POST {{baseUrl}}/api/v1/prompts
Content-Type: application/json

{
  "flow_type": "document",
  "name": "Document v2",
  "blocks": [
    {
      "block_key": "agent",
      "system_prompt": "Voce gera documentacao tecnica usando o contexto {{language_context}}."
    }
  ]
}

### -----------------------
### POST Activate Prompt Version
### -----------------------
POST {{baseUrl}}/api/v1/prompts/document/2/activate

### -----------------------
### GET Models
### -----------------------
GET {{baseUrl}}/api/v1/models

### -----------------------
### GET Default Model
### -----------------------
GET {{baseUrl}}/api/v1/models/default

### -----------------------
### POST Create Model
### -----------------------
POST {{baseUrl}}/api/v1/models
Content-Type: application/json

{
  "name": "anthropic/claude-3.5-haiku"
}

### -----------------------
### PATCH Model
### -----------------------
PATCH {{baseUrl}}/api/v1/models/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "is_default": true
}

### -----------------------
### DELETE Model
### -----------------------
DELETE {{baseUrl}}/api/v1/models/00000000-0000-0000-0000-000000000000

### -----------------------
### POST Batch
### -----------------------
POST {{baseUrl}}/api/v1/batch
Content-Type: application/json

{
  "continue_on_error": true,
  "notify": false,
  "items": [
    {
      "flow_type": "document",
      "payload": {
        "code": "export async function chargeCustomer(customerId: string, amount: number) { if (amount <= 0) throw new Error('invalid amount'); await repository.save({ customerId, amount }); return { approved: true }; }",
        "language": "typescript",
        "doc_type": "technical"
      }
    },
    {
      "flow_type": "tests",
      "payload": {
        "code": "export function charge(amount: number) { if (amount <= 0) throw new Error('invalid amount'); return amount > 0; }",
        "language": "typescript",
        "test_framework": "vitest"
      }
    }
  ]
}

### -----------------------
### GET History - List Latest
### -----------------------
GET {{baseUrl}}/api/v1/history

### -----------------------
### GET History - By ID (replace with actual UUID)
### -----------------------
GET {{baseUrl}}/api/v1/history/00000000-0000-0000-0000-000000000000
